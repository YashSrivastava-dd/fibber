# Copy to .env.local and fill in values. Do not commit .env.local.

# Site URL for SEO (robots.txt, sitemap.xml). Use production URL.
NEXT_PUBLIC_SITE_URL=https://fiberisefit.com

# Shiprocket API (Settings > API > Create API User in Shiprocket panel)
SHIPROCKET_EMAIL=your-shiprocket-api-email@example.com
SHIPROCKET_PASSWORD=your-shiprocket-api-password
